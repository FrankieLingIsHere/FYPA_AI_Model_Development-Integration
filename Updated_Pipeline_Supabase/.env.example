# Supabase Configuration (required)
# Find these in Supabase Dashboard -> Project Settings -> API / Database
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:your-db-password@db.your-project-id.supabase.co:5432/postgres

# Zero-Touch Device Provisioning & Notifications
# Generate strong random secrets for both ADMIN_PASSWORD and BOOTSTRAP_TOKEN_SECRET on cloud backend
ADMIN_PASSWORD=your-secret-admin-password
# CLOUD_URL is your deployed backend base URL (e.g. Railway public URL)
CLOUD_URL=https://your-cloud-dashboard-url
# Optional: persist local machine_id/provisioning state outside refreshed source folder
# LUNA_STATE_DIR=C:\LUNA_System\LUNA_LocalState
# Optional: reduce deferred Supabase offline startup logs from warning -> info/debug/silent
# SUPABASE_OFFLINE_LOG_LEVEL=info
# Optional: automatic provisioning poll on backend startup (for zero-touch local onboarding)
# STARTUP_AUTO_PROVISION_LOCAL_MODE=true
# STARTUP_AUTO_PROVISION_POLL_INTERVAL_SECONDS=15
# STARTUP_AUTO_PROVISION_MAX_ATTEMPTS=0
# Optional: webhook channel for pending/approved device notifications
NOTIFICATION_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# Email Notifications (Optional - for Provisioning & System Alerts)
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=your-email@outlook.com
SMTP_PASSWORD=your-app-password
ADMIN_EMAIL=admin-receiver@example.com
SMTP_TIMEOUT_SECONDS=8
SMTP_FORCE_IPV4=true
SMTP_PASSWORD_STRIP_SPACES=true
NOTIFICATION_ASYNC=true

# Optional HTTPS email fallback (recommended when SMTP egress is blocked)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=LUNA Alerts <alerts@your-domain.com>
# RESEND_API_BASE_URL=https://api.resend.com

# Storage buckets (optional - defaults shown)
SUPABASE_IMAGES_BUCKET=violation-images
SUPABASE_REPORTS_BUCKET=reports

# Signed URL expiry in seconds (optional)
SUPABASE_SIGNED_URL_TTL_SECONDS=3600

# Upload PDF reports to storage (optional)
UPLOAD_PDF=false

# Provider routing and hosted safety (optional)
# Gemini-only recommended setup.
MODEL_API_ENABLED=false

# Provider order controls
NLP_PROVIDER_ORDER=gemini,ollama,local
EMBEDDING_PROVIDER_ORDER=ollama
VISION_PROVIDER_ORDER=gemini,ollama

# On hosted containers (e.g. Railway free tier), keep local Ollama embeddings disabled
# to avoid runtime model-size pressure and local Ollama dependency.
DISABLE_OLLAMA_EMBEDDINGS=true
ALLOW_LOCAL_OLLAMA_IN_CONTAINER=false

# Gemini / Google AI (recommended for higher report quality)
# Single key (either var name works):
# GEMINI_API_KEY=your_primary_key
# GOOGLE_API_KEY=your_primary_key

# Optional key pool for automatic failover on quota/rate-limit events:
# GEMINI_API_KEYS=key_1,key_2
# GOOGLE_API_KEYS=key_1,key_2

# Paid plan tuning (set true if you are on paid API plan)
GEMINI_PAID_PLAN=true

# Recommended: use a stronger report model than vision model when budget allows
GEMINI_MODEL=gemini-2.5-flash
GEMINI_REPORT_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

# Optional: lower interval for paid plan; leave unset to auto-default
# GEMINI_MIN_INTERVAL=0.35
