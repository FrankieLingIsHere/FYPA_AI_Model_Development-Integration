# Supabase Configuration (required)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:your-db-password@db.your-project-id.supabase.co:5432/postgres

# Storage buckets (optional - defaults shown)
SUPABASE_IMAGES_BUCKET=violation-images
SUPABASE_REPORTS_BUCKET=reports

# Signed URL expiry in seconds (optional)
SUPABASE_SIGNED_URL_TTL_SECONDS=3600

# Upload PDF reports to storage (optional)
UPLOAD_PDF=false

# Provider routing and hosted safety (optional)
# Gemini-only recommended setup.
MODEL_API_ENABLED=false

# Provider order controls
NLP_PROVIDER_ORDER=gemini,ollama,local
EMBEDDING_PROVIDER_ORDER=ollama
VISION_PROVIDER_ORDER=gemini,ollama

# On hosted containers (e.g. Railway free tier), keep local Ollama embeddings disabled
# to avoid runtime model-size pressure and local Ollama dependency.
DISABLE_OLLAMA_EMBEDDINGS=true
ALLOW_LOCAL_OLLAMA_IN_CONTAINER=false
